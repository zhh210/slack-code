# Slack Bot Tokens (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Optional: Anthropic API Key (if not using Claude Code's default auth)
# ANTHROPIC_API_KEY=sk-ant-...

# Working directory for Claude Code operations
CLAUDE_WORKING_DIR=/path/to/your/project

# Optional: Slack user token for cross-channel search (requires search:read scope)
# SLACK_USER_TOKEN=xoxp-your-user-token
